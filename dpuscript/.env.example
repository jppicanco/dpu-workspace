# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env

# === e-Proc TNU ===
# CPF (apenas números) ou login do sistema e-Proc TNU
EPROC_USUARIO=seu_cpf_ou_login
# Senha do e-Proc TNU
EPROC_SENHA=sua_senha_eproc
# Perfil no e-Proc: formato ASP<CPF> — ex: ASP12345678900
EPROC_PERFIL=ASP<SEU_CPF>

# === SISDPU ===
SISDPU_USERNAME=seu_usuario_sisdpu
SISDPU_PASSWORD=sua_senha_sisdpu

# === Telegram (opcional — notificações quando pipeline conclui) ===
# Crie um bot em https://t.me/BotFather e obtenha o token
TELEGRAM_BOT_TOKEN=
# ID do chat (use @userinfobot para descobrir o seu)
TELEGRAM_CHAT_ID=
